# .env.example — コピーして .env を作成し、各キーを設定してください。
# cp .env.example .env

# 必須: Gemini API キー（https://aistudio.google.com/apikey）
GEMINI_API_KEY=

# 任意: ペルソナ
AICP_PERSONA_NAME=Jarvis     # コンパニオンの名前（既定: Jarvis）
AICP_USER_NICKNAME=          # 相手の呼び方（未設定なら会話中に尋ねる）

# 任意: ウェイクワード
# 事前学習済みモデル名: hey_jarvis / alexa / hey_mycroft / hey_rhasspy ...
AICP_WAKE_MODEL=hey_jarvis
AICP_WAKE_THRESHOLD=0.1
# カスタムモデルを使う場合は .onnx / .tflite のパスを指定（こちらが優先）
# AICP_WAKE_MODEL_PATH=/path/to/my_wakeword.onnx

# 任意: モデル・音声
AICP_LIVE_MODEL=gemini-3.1-flash-live-preview
AICP_VOICE=Zephyr

# 任意: 挙動
AICP_SILENCE_TIMEOUT=45      # 無音で会話終了する秒数
# AICP_MUTE_MIC_DURING_OUTPUT=true  # 既定 on。AI 発話中にマイクを API へ送らない（false で割り込みしやすく）
AICP_BARGE_IN_PREFIX_MS=500  # 何 ms 続いた発話で割り込みとみなすか（VAD）
AICP_LOG_LEVEL=INFO

# 任意: 長期記憶（常時有効）
# AICP_MEMORY_DIR=                    # 既定: ~/Library/Application Support/ai_companion/memory/
# AICP_MEMORY_RECENT_SESSIONS=3       # 会話開始時に注入する直近セッション数
# AICP_MEMORY_MODEL=gemini-2.0-flash  # 会話終了後の要約・fact 抽出モデル
